{
  "schedule": "0 8 * * 1,3,5",
  "outputDir": "./data",
  "exportXlsx": true,
  "smokeSaveLog": true,
  "captcha": {
    "sessionFile": "./data/session.json",
    "provider": "rucaptcha",
    "fallbackProvider": "2captcha"
  },
  "retry": {
    "attempts": 3,
    "backoffMs": 2000,
    "timeoutMs": 15000
  },
  "viewer": {
    "port": 3000,
    "host": "localhost"
  }
}
